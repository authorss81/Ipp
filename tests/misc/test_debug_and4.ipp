# Test and operator outside of class

var a = true
var b = true
print("a and b:", a and b)
print("(a) and (b):", (a) and (b))

var x = 1 == 1
var y = 2 == 2
print("x and y:", x and y)
print("(x) and (y):", (x) and (y))

# Direct comparison
print("1 == 1 and 2 == 2:", 1 == 1 and 2 == 2)
print("(1 == 1) and (2 == 2):", (1 == 1) and (2 == 2))