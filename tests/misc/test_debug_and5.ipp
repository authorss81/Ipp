# Test and operator evaluation

# Test 1: Simple and
print("Test 1: true and true:", true and true)

# Test 2: Comparison and
print("Test 2: 1 == 1 and 2 == 2:", 1 == 1 and 2 == 2)

# Test 3: With parentheses
print("Test 3: (1 == 1) and (2 == 2):", (1 == 1) and (2 == 2))

# Test 4: Store in variable
var a = 1 == 1
var b = 2 == 2
print("Test 4: a and b:", a and b)

# Test 5: Direct comparison
var x = 1
var y = 1
print("Test 5: x == y and true:", x == y and true)