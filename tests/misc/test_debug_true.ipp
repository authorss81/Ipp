# Debug true/false values

print("true value:", true)
print("false value:", false)
print("type(true):", type(true))
print("type(false):", type(false))
print("bool(1):", bool(1))
print("bool(0):", bool(0))

var x = true
var y = true
print("x and y:", x and y)
print("x == true:", x == true)
print("y == true:", y == true)

var result = x and y
print("result:", result)
print("result == true:", result == true)
print("result == false:", result == false)